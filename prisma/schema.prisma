generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  address   String?
  lat       Float
  lng       Float
  radius    Int      @default(100)
  isActive  Boolean  @default(true)

  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedReason String?

  deletedById Int?
  deletedBy   Employees? @relation("BranchDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees         Employees[]
  positions         Position[]
  holidays          StoreHoliday[]
  calendarNotes     CalendarNote[]
  overtimeTrackings OvertimeTracking[]

  notifications Notification[] @relation("NotificationBranch")
  auditLogs     AuditLog[]     @relation("AuditLogBranch")

  @@index([isActive])
  @@index([isDeleted])
  @@index([deletedAt])
  @@index([deletedById])
}

model Employees {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  firstname        String
  lastname         String
  phone            String?
  emergencyContact String?
  profileImage     String?
  publicId         String?
  baseSalary       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  role             Role     @default(USER)

  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedReason String?

  deletedById      Int?
  deletedBy        Employees?  @relation("EmployeeDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedEmployees Employees[] @relation("EmployeeDeletedBy")

  deletedBranches  Branch[]   @relation("BranchDeletedBy")
  deletedPositions Position[] @relation("PositionDeletedBy")
  deletedShifts    Shift[]    @relation("ShiftDeletedBy")

  remainingDayOffs     Int @default(0)
  lastDayOffResetMonth Int?
  lastDayOffResetYear  Int?

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  positionId Int?
  position   Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  timetracking      TimeTracking[]
  overtimeTrackings OvertimeTracking[]
  dayOff            DayOff[]
  advanceSalary     AdvanceSalary[]
  salaryRecord      SalaryRecord[]
  employeeShifts    EmployeeShift[]

  createdNotifications  Notification[]          @relation("NotificationCreatedBy")
  notificationRecipients NotificationRecipient[]

  auditLogsAsActor  AuditLog[] @relation("AuditActor")
  auditLogsAsTarget AuditLog[] @relation("AuditTargetEmployee")

  monthlyHistorySnapshots MonthlyHistorySnapshot[]

  @@index([isActive])
  @@index([isDeleted])
  @@index([deletedAt])
  @@index([deletedById])
  @@index([branchId])
  @@index([positionId])
  @@index([role])
}

enum Role {
  USER
  ADMIN
  OWNER
}

model TimeTracking {
  id       Int       @id @default(autoincrement())
  checkIn  DateTime? @default(now())
  checkOut DateTime? @db.Timestamp(0)
  date     DateTime  @default(now())

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: SetNull)

  lateMinutes       Int     @default(0)
  earlyLeaveMinutes Int     @default(0)
  checkInNote       String?
  checkOutNote      String?

  shiftId Int?
  shift   Shift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  shiftNameSnapshot    String?
  positionIdSnapshot   Int?
  positionNameSnapshot String?

  scheduledCheckInTime  String?
  scheduledCheckOutTime String?

  checkInGraceBeforeMinutesSnapshot Int?
  checkOutGraceAfterMinutesSnapshot Int?

  branchIdSnapshot   Int?
  branchNameSnapshot String?

  status TimeTrackingStatus @default(ACTIVE)

  @@unique([employeesId, date, shiftId])
  @@index([employeesId])
  @@index([date])
  @@index([shiftId])
  @@index([status])
  @@index([branchIdSnapshot])
  @@index([positionIdSnapshot])
}

enum TimeTrackingStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
  MANUAL
}

model OvertimeTracking {
  id       Int       @id @default(autoincrement())
  checkIn  DateTime  @default(now())
  checkOut DateTime?
  date     DateTime  @default(now())

  noteIn    String?
  noteOut   String?
  otMinutes Int      @default(0)
  status    OTStatus @default(ACTIVE)

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: SetNull)

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeesId])
  @@index([branchId])
  @@index([date])
  @@index([status])
}

enum OTStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model DayOff {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  reason    String?
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)
  status    Status   @default(PENDING)

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: SetNull)

  @@index([employeesId])
  @@index([date])
  @@index([status])
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

model AdvanceSalary {
  id          Int      @id @default(autoincrement())
  requestDate DateTime
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)
  status      Status   @default(PENDING)

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: SetNull)

  @@index([employeesId])
  @@index([requestDate])
  @@index([status])
}

model SalaryRecord {
  id           Int      @id @default(autoincrement())
  month        DateTime @default(now())
  baseSlary    Decimal  @db.Decimal(10, 2)
  advanceTaken Decimal  @db.Decimal(10, 2)
  finalSalary  Decimal  @db.Decimal(10, 2)

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: SetNull)

  @@index([employeesId])
  @@index([month])
}

model Position {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  checkInTime       String
  checkOutTime      String
  maxDayOffPerMonth Int      @default(0)

  allowOT      Boolean @default(false)
  otCapMinutes Int?

  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedReason String?

  deletedById Int?
  deletedBy   Employees? @relation("PositionDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employees[]
  shifts    Shift[]

  @@unique([branchId, name])
  @@index([branchId])
  @@index([isActive])
  @@index([isDeleted])
  @@index([deletedAt])
  @@index([deletedById])
}

model StoreHoliday {
  id    Int      @id @default(autoincrement())
  date  DateTime
  title String?

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedById   Int?
  deletedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([branchId])
  @@index([date])
  @@index([isDeleted])
  @@index([date, branchId, isDeleted])
}

model Shift {
  id           Int      @id @default(autoincrement())
  name         String
  checkInTime  String
  checkOutTime String
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)

  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedReason String?

  deletedById Int?
  deletedBy   Employees? @relation("ShiftDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  checkInGraceBeforeMinutes Int @default(30)
  checkOutGraceAfterMinutes Int @default(180)

  positionId Int
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  employeeShifts EmployeeShift[]
  timeTrackings   TimeTracking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([positionId, name])
  @@index([positionId])
  @@index([isActive])
  @@index([isDeleted])
  @@index([deletedAt])
  @@index([deletedById])
}

model EmployeeShift {
  id   Int      @id @default(autoincrement())
  date DateTime

  employeesId Int
  employees   Employees @relation(fields: [employeesId], references: [id], onDelete: Cascade)

  shiftId Int
  shift   Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeesId, date])
  @@index([employeesId])
  @@index([shiftId])
  @@index([date])
}

model CalendarNote {
  id    Int      @id @default(autoincrement())
  date  DateTime
  title String
  note  String?

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedById   Int?
  deletedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([branchId])
  @@index([isDeleted])
}
enum NotificationType {
  REQUEST_CREATED
  REQUEST_APPROVED
  REQUEST_REJECTED
  HOLIDAY_CREATED
  CALENDAR_NOTE_CREATED
  CALENDAR_NOTE_DELETED
  HOLIDAY_DELETED
  SYSTEM
}

enum NotificationTargetType {
  USER
  ADMIN
  OWNER
  ALL
  BRANCH
}

model Notification {
  id       Int              @id @default(autoincrement())
  type     NotificationType
  title    String
  message  String?
  link     String?
  entity   String?
  entityId Int?

  targetType NotificationTargetType @default(USER)

  branchId Int?
  branch   Branch? @relation("NotificationBranch", fields: [branchId], references: [id], onDelete: SetNull)

  createdById Int?
  createdBy   Employees? @relation("NotificationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  recipients NotificationRecipient[]

  createdAt DateTime @default(now())

  @@index([type])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([branchId])
  @@index([createdById])
}

model NotificationRecipient {
  id Int @id @default(autoincrement())

  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  employeesId Int
  employees   Employees @relation(fields: [employeesId], references: [id], onDelete: Cascade)

  isRead Boolean @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@unique([notificationId, employeesId])
  @@index([employeesId])
  @@index([isRead])
  @@index([createdAt])
}

enum AuditAction {
  ADD_USER
  DELETE_USER
  UPDATE_USER
  ADD_BRANCH
  UPDATE_BRANCH
  DELETE_BRANCH
  ADD_POSITION
  UPDATE_POSITION
  DELETE_POSITION
  CHANGE_POSITION
  CHANGE_BRANCH
  CHANGE_SALARY
  APPROVE_REQUEST
  REJECT_REQUEST
  ADD_CALENDAR_NOTE
  UPDATE_CALENDAR_NOTE
  DELETE_CALENDAR_NOTE
  SET_STORE_HOLIDAY
  DELETE_STORE_HOLIDAY

  CREATE_SHIFT
  UPDATE_SHIFT
  DELETE_SHIFT

  MANUAL_TIME_EDIT
  SYSTEM
}

model AuditLog {
  id Int @id @default(autoincrement())

  action AuditAction

  entity   String
  entityId Int?

  actorId Int?
  actor   Employees? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  targetEmployeeId Int?
  targetEmployee   Employees? @relation("AuditTargetEmployee", fields: [targetEmployeeId], references: [id], onDelete: SetNull)

  branchId Int?
  branch   Branch? @relation("AuditLogBranch", fields: [branchId], references: [id], onDelete: SetNull)

  oldValue Json?
  newValue Json?
  note     String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity, entityId])
  @@index([actorId])
  @@index([targetEmployeeId])
  @@index([branchId])
  @@index([createdAt])
}

model MonthlyHistorySnapshot {
  id          Int       @id @default(autoincrement())
  employeesId Int
  employee    Employees @relation(fields: [employeesId], references: [id], onDelete: Cascade)

  month DateTime

  remainingDayOffs Int @default(0)
  salaryLeft       Int @default(0)
  workingDays      Int @default(0)
  lateDays         Int @default(0)
  absentDays       Int @default(0)
  totalOTMinutes   Int @default(0)
  dayOffUsed       Int @default(0)
  advanceTaken     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeesId, month])
  @@index([employeesId])
  @@index([month])
}