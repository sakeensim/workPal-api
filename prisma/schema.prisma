generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  address   String?
  lat       Float
  lng       Float
  radius    Int      @default(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees         Employees[]
  holidays          StoreHoliday[]
  calendarNotes     CalendarNote[]
  overtimeTrackings OvertimeTracking[]
}

model Employees {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  firstname        String
  lastname         String
  phone            String?
  emergencyContact String?
  profileImage     String?
  publicId         String?
  baseSalary       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  role             Role     @default(USER)

  remainingDayOffs     Int @default(0)
  lastDayOffResetMonth Int?
  lastDayOffResetYear  Int?

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  positionId Int?
  position   Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  timetracking      TimeTracking[]
  overtimeTrackings OvertimeTracking[]
  dayOff            DayOff[]
  advanceSalary     AdvanceSalary[]
  salaryRecord      SalaryRecord[]
  employeeShifts    EmployeeShift[]
}

enum Role {
  USER
  ADMIN
  OWNER
}

model TimeTracking {
  id       Int       @id @default(autoincrement())
  checkIn  DateTime? @default(now())
  checkOut DateTime? @db.Timestamp(0)
  date     DateTime  @default(now())

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: SetNull)

  lateMinutes       Int     @default(0)
  earlyLeaveMinutes Int     @default(0)
  checkInNote       String?
  checkOutNote      String?

  shiftId Int?
  shift   Shift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  
  @@unique([employeesId, date, shiftId])
}

model OvertimeTracking {
  id       Int       @id @default(autoincrement())
  checkIn  DateTime  @default(now())
  checkOut DateTime?
  date     DateTime  @default(now())

  noteIn    String?
  noteOut   String?
  otMinutes Int      @default(0)
  status    OTStatus @default(ACTIVE)

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: SetNull)

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeesId])
  @@index([branchId])
  @@index([date])
  @@index([status])
}

enum OTStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model DayOff {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  reason    String?
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.Timestamp(0)
  status    Status   @default(PENDING)

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: SetNull)
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

model AdvanceSalary {
  id          Int      @id @default(autoincrement())
  requestDate DateTime
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @db.Timestamp(0)
  status      Status   @default(PENDING)

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: Cascade)
}

model SalaryRecord {
  id           Int      @id @default(autoincrement())
  month        DateTime @default(now())
  baseSlary    Decimal  @db.Decimal(10, 2)
  advanceTaken Decimal  @db.Decimal(10, 2)
  finalSalary  Decimal  @db.Decimal(10, 2)

  employeesId Int?
  employees   Employees? @relation(fields: [employeesId], references: [id], onDelete: SetNull)
}

model Position {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  description       String?
  checkInTime       String
  checkOutTime      String
  maxDayOffPerMonth Int      @default(0)

  allowOT      Boolean @default(false)
  otCapMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employees[]
  shifts    Shift[]
}

model StoreHoliday {
  id    Int      @id @default(autoincrement())
  date  DateTime
  title String?

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([date, branchId])
}

model Shift {
  id           Int      @id @default(autoincrement())
  name         String
  checkInTime  String
  checkOutTime String
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)

  positionId Int
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  employeeShifts EmployeeShift[]
  timeTrackings   TimeTracking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([positionId, name])
}

model EmployeeShift {
  id   Int      @id @default(autoincrement())
  date DateTime

  employeesId Int
  employees   Employees @relation(fields: [employeesId], references: [id], onDelete: Cascade)

  shiftId Int
  shift   Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeesId, date])
}

model CalendarNote {
  id    Int      @id @default(autoincrement())
  date  DateTime
  title String
  note  String?

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([branchId])
}